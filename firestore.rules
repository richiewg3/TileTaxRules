rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(authorId) {
      return isSignedIn() && request.auth.uid == authorId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Helpers ---
    function isValidTileset(data) {
      return data.keys().hasAll(['name', 'type', 'imageUrl', 'authorId', 'createdAt', 'updatedAt'])
        && data.keys().size() >= 6
        && data.name is string && data.name.size() <= 256
        && data.type in ['blob', 'transition', 'cave']
        && data.authorId == request.auth.uid
        && data.createdAt == request.time
        && data.updatedAt == request.time;
    }

    function isValidAsset(data) {
      return data.keys().hasAll(['name', 'imageUrl', 'authorId', 'createdAt', 'updatedAt'])
        && data.keys().size() >= 5
        && data.name is string && data.name.size() <= 256
        && data.authorId == request.auth.uid
        && data.createdAt == request.time
        && data.updatedAt == request.time;
    }

    match /tilesets/{tilesetId} {
      allow read: if isSignedIn() && resource.data.authorId == request.auth.uid;
      allow create: if isSignedIn() && isValidTileset(incoming()) && isValidId(tilesetId);
      allow update: if isSignedIn() && isOwner(existing().authorId) 
        && incoming().authorId == existing().authorId
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time
        && (incoming().diff(existing()).affectedKeys().hasOnly(['name', 'rulesJSON', 'updatedAt', 'imageUrl', 'ruleMode']));
      allow delete: if isOwner(existing().authorId);
    }

    match /assets/{assetId} {
      allow read: if isSignedIn() && resource.data.authorId == request.auth.uid;
      allow create: if isSignedIn() && isValidAsset(incoming()) && isValidId(assetId);
      allow update: if isSignedIn() && isOwner(existing().authorId) 
        && incoming().authorId == existing().authorId
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time
        && (incoming().diff(existing()).affectedKeys().hasOnly(['name', 'imageUrl', 'updatedAt', 'metadata']));
      allow delete: if isOwner(existing().authorId);
    }
  }
}
